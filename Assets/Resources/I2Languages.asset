      - "B\u1ED9 s\u01A1 c\u1EE9u"
      - "\u03BA\u03B9\u03C4 \u03C0\u03C1\u03CE\u03C4\u03C9\u03BD \u03B2\u03BF\u03B7\u03B8\u03B5\u03B9\u03CE\u03BD"
