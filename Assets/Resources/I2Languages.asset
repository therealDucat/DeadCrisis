    - Term: i_ShotgunShellsDesc
      TermType: 0
      Description: 
      Languages:
      - 12 gauge shotgun shells
      - "\u041F\u0430\u0442\u0440\u043E\u043D\u044B \u0434\u043B\u044F \u0434\u0440\u043E\u0431\u043E\u0432\u0438\u043A\u0430
