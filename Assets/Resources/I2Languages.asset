      - "\u6211\u5011\u5728\u7B49\u4F60\uFF01\nXOXO"
      - "\uC6B0\uB9AC\uB294 \uB2F9\uC2E0\uC744 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC2B5\uB2C8\uB2E4!\nXOXO"
