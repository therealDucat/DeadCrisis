      - "V\u0103 a\u0219tept\u0103m!\nXOXO"
      - "\u0E40\u0E23\u0E32\u0E01\u0E33\u0E25\u0E31\u0E07\u0E23\u0E2D\u0E04\u0E38\u0E13\u0E2D\u0E22\u0E39\u0E48!\n\u0E08\u0E38\u0E4A\u0E46"
